# Wukong Voyager bridge environment template.
#
# Copy to /Users/frank/.voyager/bridge.env, edit locally, and chmod 600.
# Do not commit the real file. launchd sources it before starting uvicorn.

PYTHONUNBUFFERED=1
VOYAGER_CONFIG_PATH=/Users/frank/.voyager/config.toml

# Production writes are enabled only when dry-run is explicitly false and the
# target repository is allow-listed. Keep the global fallback unset unless a
# future route intentionally depends on it.
DRY_RUN=false
# BRIDGE_ALLOWED_REPOSITORIES=

# Current Wukong canary scope from issue #44. Do not add more repositories here
# until the staged expansion checklist is approved.
BRIDGE_ALLOWED_REPOSITORIES_ITERWHEEL_BLUEPRINT=frankyxhl/alfred,frankyxhl/trinity,iterwheel/voyager
BRIDGE_ALLOWED_REPOSITORIES_ITERWHEEL_STACK=frankyxhl/alfred,frankyxhl/trinity,iterwheel/voyager
BRIDGE_ALLOWED_REPOSITORIES_ITERWHEEL_CLEARANCE=iterwheel/voyager
BRIDGE_ALLOWED_REPOSITORIES_ITERWHEEL_CHANGELOG=iterwheel/voyager
# Branch cleanup uses a cleanup-specific route slug. Do not allow-list
# iterwheel-assembly here; that would also enable /assembly implementation routes.
BRIDGE_ALLOWED_REPOSITORIES_ITERWHEEL_CLEANUP=iterwheel/voyager

# Assembly verification defaults to Voyager's command set. When Assembly is
# expanded to a non-Voyager repository, use an operator-trusted repo-specific
# override. Commands are split on newlines or `;;`.
# ASSEMBLY_VERIFICATION_COMMANDS_FRANKYXHL__TRINITY="make verify-built;;af validate --root ."

# Repository webhook secret fallback and app-specific webhook secrets. The
# server reads GITHUB_REPOSITORY_WEBHOOK_SECRET for repository-level webhooks.
# Use the exact values from the GitHub webhook/App settings.
GITHUB_REPOSITORY_WEBHOOK_SECRET=replace-with-repository-webhook-secret
GITHUB_WEBHOOK_SECRET_ITERWHEEL_BLUEPRINT=replace-with-blueprint-webhook-secret
GITHUB_WEBHOOK_SECRET_ITERWHEEL_STACK=replace-with-stack-webhook-secret
GITHUB_WEBHOOK_SECRET_ITERWHEEL_CLEARANCE=replace-with-clearance-webhook-secret

# Optional Clearance investigator key. Leave unset if Clearance should not call
# the external investigator in this deployment.
# VOYAGER_DEEPSEEK_API_KEY=replace-with-deepseek-api-key

# Optional local test-bot bypass for canary repositories. Keep unset in normal
# production unless an operator is running a controlled test.
# VOYAGER_TEST_BOT_LOGINS=chatgpt-codex-connector[bot]
